# ---- Database ----
# Local dev uses the Docker Postgres from docker-compose.yml (host port 55432).
DATABASE_URL="postgresql://omnischools:omnischools@localhost:55432/omnischools_dev"

# ---- Supabase (wired at deploy; leave blank for local Docker dev) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- SMS (Hubtel) — blank = console stub ----
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=Omnischools

# ---- Email (Resend) — blank = console stub ----
RESEND_API_KEY=

# ---- Observability (dormant unless set) ----
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ---- Background jobs (generic HTTP cron shared secret) ----
CRON_SECRET=

# ---- Public site URL (used for metadata/sitemap; set to your deploy URL in prod) ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Dev auth shim ----
# true = ADMIN dev session, no provider needed (local dev).
# false + Supabase env set = real Supabase phone-OTP auth (see DEPLOY.md).
AUTH_DEV_BYPASS=true
# Optional, DEV ONLY: pin the shim session's roles (comma-separated) instead of ADMIN — the sickbay
# is MATRON-gated, so its UI and mutations are unreachable in dev without this. Read ONLY when
# AUTH_DEV_BYPASS is true; unset = today's behaviour (ADMIN). Never set it in production.
# AUTH_DEV_ROLES=MATRON
